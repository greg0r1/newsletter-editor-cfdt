# Authentification (mot de passe partagé)
AUTH_PASSWORD=change-me
AUTH_SECRET=une-longue-chaine-aleatoire-pour-signer-le-cookie

# Générées automatiquement par l'intégration Vercel Marketplace > Supabase
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Générée automatiquement par l'intégration Vercel Blob
BLOB_READ_WRITE_TOKEN=

# Optionnelles : générées automatiquement par l'intégration Vercel Marketplace
# > Upstash (Redis). Sans elles, le rate limiting de /api/login est
# désactivé silencieusement (le login reste fonctionnel).
KV_REST_API_URL=
KV_REST_API_TOKEN=
